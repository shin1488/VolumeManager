  <key>CFBundleInfoDictionaryVersion</key>
  <string>6.0</string>

  <key>CFBundleName</key>
  <string>VolumeManagerDevice</string>

  <key>CFBundlePackageType</key>
  <string>BNDL</string>

  <key>CFBundleShortVersionString</key>
  <string>0.1.0</string>

  <key>CFBundleSignature</key>
  <string>APLG</string>

  <key>CFBundleVersion</key>
  <string>1</string>

  <key>CFPlugInDynamicRegistration</key>
  <string>NO</string>

  <key>CFPlugInFactories</key>
  <dict>
    <!-- TODO(macos): generate a real UUID and mirror it in the .cpp file. -->
    <key>00000000-0000-0000-0000-0000DEADBEEF</key>
    <string>VolumeManagerPlugIn_Create</string>
  </dict>

  <key>CFPlugInTypes</key>
